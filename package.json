{
  "name": "@reclaimprotocol/zk-fetch",
  "version": "1.0.0",
  "description": "HTTPS Fetch with a zkproof of correctness of fetch",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "lib"
  ],
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "splitting": false,
    "sourcemap": true,
    "clean": true,
    "external": [
      "@reclaimprotocol/tls",
      "@reclaimprotocol/tls/webcrypto",
      "@reclaimprotocol/zk-symmetric-crypto",
      "koffi"
    ]
  },
  "scripts": {
    "build": "sh build.sh",
    "download:circuits": "node node_modules/@reclaimprotocol/zk-symmetric-crypto/lib/scripts/download-files",
    "test": "vitest"
  },
  "author": "madhavanmalolan",
  "license": "SEE LICENSE IN https://github.com/reclaimprotocol/zk-fetch/blob/master/LICENSE.md",
  "dependencies": {
    "@reclaimprotocol/attestor-core": "5.0.5",
    "@swc/core": "^1.6.13",
    "ethers": "^5.7.2",
    "pino": "^8.20.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/uuid": "^9.0.8",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reclaimprotocol/zk-fetch"
  },
  "keywords": [
    "zk",
    "fetch",
    "reclaimprotocol"
  ]
}
